---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout
	title={t('firm.title')}
	description={t('firm.description')}
	navbarDarkMode={true}
>
	<div class="bg-light-gray px-6 md:px-12 lg:px-20 pt-16 md:pt-24">
		<div class="max-w-360 mx-auto">
			<video class="w-full mix-blend-multiply" autoplay muted playsinline src="/videos/logo_video.mp4"></video>
		</div>
	</div>

	<section class="dynamic-section-trigger bg-light-gray">
		<div class="max-w-360 mx-auto h-svh flex flex-col md:flex-row pt-16 md:pt-24 md:pb-24">

			<div class="relative flex-1 order-2 md:order-1 md:w-1/2">
				<div class="dynamic-panel absolute inset-0 flex flex-col justify-start space-y-4 px-6 md:px-12 lg:px-16 py-6 md:py-12">
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed" set:html={t('firm.p1')} />
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed" set:html={t('firm.p2')} />
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed">{t('firm.p3')}</p>
				</div>
				<div class="dynamic-panel absolute inset-0 flex flex-col justify-start space-y-4 px-6 md:px-12 lg:px-16 py-6 md:py-12">
					<h3 class="text-dark-slate text-2xl md:text-3xl font-semibold tracking-wide">{t('firm.enfoque.title')}</h3>
					<div class="w-16 h-0.75 bg-bronze"></div>
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed">{t('firm.enfoque.p1')}</p>
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed">{t('firm.enfoque.p2')}</p>
				</div>
				<div class="dynamic-panel absolute inset-0 opacity-0 flex flex-col space-y-4 px-6 md:px-12 lg:px-16 py-6 md:py-12">
					<h3 class="text-dark-slate text-2xl md:text-3xl font-semibold tracking-wide">{t('firm.consultoria.title')}</h3>
					<div class="w-16 h-0.75 bg-bronze mb-6"></div>
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed">{t('firm.consultoria.p1')}</p>
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed">{t('firm.consultoria.p2')}</p>
				</div>
				<div class="dynamic-panel absolute inset-0 opacity-0 flex flex-col px-6 md:px-12 lg:px-16 py-6 md:py-12">
					<h3 class="text-dark-slate text-2xl md:text-3xl font-semibold tracking-wide mb-4 uppercase">{t('firm.mision.title')}</h3>
					<div class="w-16 h-0.75 bg-bronze mb-6"></div>
					<p class="text-dark-slate text-base md:text-lg lg:text-xl font-light leading-relaxed">{t('firm.mision.p1')}</p>
				</div>
			</div>

			<div class="relative flex-none h-[20svh] md:flex-1 md:h-full order-1 md:order-2 md:w-1/2 overflow-hidden md:max-h-svh">
				<div class="dynamic-image absolute inset-0 py-12">
					<img class="w-full h-full object-cover" src="/assets/impacto/aerodom.jpg" alt="" />
				</div>
				<div class="dynamic-image absolute inset-0 opacity-0 pt-36">
					<img class="w-full h-auto object-cover" src="/assets/general/aicons.svg" alt="" />
				</div>
				<div class="dynamic-image absolute inset-0 opacity-0 py-12">
					<img class="w-full h-full object-cover" src="/assets/impacto/deportiva.jpg" alt="" />
				</div>
				<div class="dynamic-image absolute inset-0 opacity-0 py-12">
					<img class="w-full h-full object-cover" src="/assets/impacto/energas.jpg" alt="" />
				</div>
			</div>

		</div>
	</section>

	<script>
		import "../scripts/areas_gsap.js";
	</script>

</Layout>
